*.py[cod]
*$py.class
.venv/
venv/
env/
.uv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Node artifacts (in case a plugin ever ships a JS MCP server).
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editors / IDEs.
.idea/
.vscode/
*.swp
*.swo
*~

# OS.
.DS_Store
Thumbs.db

# Logs & env.
*.log
.env
.env.*
!.env.example
